SERVER_HOST=0.0.0.0
SERVER_PORT=56001
SERVER_USERNAME=admin
SERVER_PASSWORD=replace-with-a-strong-password
DATA_DIR=./data

QUARK_COOKIE=
QUARK_SIGNIN_COOKIE=
QUARK_SIGNIN_ENABLED=false
QUARK_SIGNIN_HOUR=8
PANSOU_API_URL=

ARIA2_RPC_URL=http://127.0.0.1:6800/jsonrpc
ARIA2_SECRET=
ARIA2_MOVIE_DIR=/downloads/电影
ARIA2_SERIES_DIR=/downloads/连续剧
ARIA2_ANIME_DIR=/downloads/动画

STRM_ENABLED=false
STRM_OUTPUT_DIR=/media/strm
STRM_PUBLIC_BASE_URL=http://127.0.0.1:56001
STRM_ACCESS_TOKEN=
STRM_TOKEN_IN_URL=false

TMDB_API_KEY=
TMDB_LANGUAGE=zh-CN

# 企业微信机器人 webhook
# WECOM_BOT_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# WxPusher 推送
# WXPUSHER_APP_TOKEN=AT_xxxx
# WXPUSHER_UIDS=UID_xxx,UID_yyy

# Telegram 推送
# TELEGRAM_BOT_TOKEN=123456:xxxx
# TELEGRAM_CHAT_ID=123456

# Bark / Gotify / PushPlus / Server 酱
# BARK_URL=https://api.day.app/your_key
# GOTIFY_URL=https://gotify.example.com
# GOTIFY_TOKEN=your_token
# PUSHPLUS_TOKEN=your_token
# SERVERCHAN_KEY=your_key

# 自动备份：0 小时可关闭定时备份
BACKUP_INTERVAL_HOURS=24
BACKUP_VERIFY_INTERVAL_HOURS=24
# BACKUP_EXTERNAL_DIR=/mnt/offsite/my-media-sub
BACKUP_RETENTION=7
BACKUP_MAX_ARCHIVE_MB=256
BACKUP_MAX_STORAGE_MB=512

# Logging
RUST_LOG=info
LOG_FORMAT=text
SLOW_OPERATION_MS=1000

# Store lifecycle retention (bounded by built-in safety caps)
RETENTION_SUBSCRIPTION_CHECKS=30
RETENTION_SOURCE_SWITCHES=50
RETENTION_PREVIOUS_LINKS=50
RETENTION_NOTIFICATIONS=300
RETENTION_ACTIVE_JOBS=300
RETENTION_ARCHIVED_JOBS=5000
RETENTION_AUTOMATION_EVENTS=5000
RETENTION_AUTOMATION_DAYS=30
RETENTION_FAILED_AUTOMATION_DAYS=90
STORE_GROWTH_WARNING_MB=24
