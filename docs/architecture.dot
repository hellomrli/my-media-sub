digraph MyMediaSub {
  graph [
    rankdir=LR,
    bgcolor="#08111f",
    pad="0.3",
    nodesep="0.28",
    ranksep="0.7",
    splines=polyline,
    fontname="Noto Sans CJK SC",
    fontcolor="#dbeafe",
    label="my-media-sub v1.13.1 当前架构",
    labelloc=t,
    fontsize=21
  ];
  node [shape=box, style="rounded,filled", fontname="Noto Sans CJK SC", fontsize=10,
        color="#334155", fontcolor="#e2e8f0", fillcolor="#111d2c", margin="0.12,0.08"];
  edge [color="#64748b", fontcolor="#a5b4fc", fontname="Noto Sans CJK SC", fontsize=8, arrowsize=0.65];

  subgraph cluster_clients {
    label="访问端"; color="#1e3a5f"; style="rounded,dashed";
    Browser [label="WebUI / PWA\nAlpine 静态模块", fillcolor="#172554", color="#3b82f6"];
    Automation [label="自动化客户端\nscoped Bearer + Idempotency-Key"];
    Telegram [label="Telegram\nLong polling / Webhook"];
    MediaClient [label="Jellyfin / Emby / Plex\nSTRM 媒体客户端"];
  }

  subgraph cluster_http {
    label="Axum 接入与安全"; color="#4c1d95"; style="rounded,dashed";
    Auth [label="Basic Auth / Bearer Scope\nCSRF + 登录限流", fillcolor="#2e1065", color="#8b5cf6"];
    TelegramAuth [label="Webhook 随机路径\nSecret Header"];
    Routes [label="src/api/*\n统一 JSON 信封", fillcolor="#312e81", color="#6366f1"];
    Static [label="ServeDir static/\nService Worker"];
    Strm [label="/strm/*\n独立 Token"];
    SSE [label="Job SSE"];
  }

  subgraph cluster_core {
    label="AppContext 与业务层"; color="#14532d"; style="rounded,dashed";
    Context [label="AppContext\n共享依赖与生命周期", fillcolor="#052e16", color="#22c55e"];
    Services [label="Services\n检查 / 进度完结 / 转存 / 换源\n元数据 / 日历 / 通知 / STRM"];
    Queue [label="JobQueue + Worker\n幂等 / 并发 / 重试 / 恢复", fillcolor="#134e4a"];
    Schedulers [label="后台服务\n订阅 / 签到 / 下载监控\n备份维护 / Telegram Bot"];
    Events [label="AutomationEvent\ncorrelation / stage / job / episode"];
    Metrics [label="Tracing + Metrics\n诊断 / Prometheus"];
    Provider [label="CloudDriveProvider\nQuark 生产 / Mock 测试"];
  }

  subgraph cluster_store {
    label="JSON 单写持久化"; color="#713f12"; style="rounded,dashed";
    Stores [label="Settings / Subscriptions / Notifications\nJobs + Archive / Automation Events\nAutomation Token / Telegram State", fillcolor="#422006", color="#f59e0b"];
    Schema [label="schema_version: 1\n原子写入 / 0600 / 迁移备份\n损坏隔离 / 未来版本保护"];
    Backup [label="备份清单 + SHA-256\n隔离恢复验证 / 外部复制"];
    Data [label="DATA_DIR", shape=cylinder, fillcolor="#422006"];
  }

  subgraph cluster_external {
    label="外部系统（失败隔离）"; color="#7f1d1d"; style="rounded,dashed";
    Search [label="PanSou"];
    Quark [label="Quark 分享 / 网盘 / 签到"];
    TMDB [label="TMDB 元数据 / 图片"];
    Aria2 [label="Aria2 JSON-RPC"];
    Library [label="Jellyfin / Emby / Plex"];
    Push [label="Browser Push / Webhook\nTelegram / 企业微信 / 其他渠道"];
  }

  Browser -> Auth [label="Basic Auth"];
  Automation -> Auth [label="Bearer"];
  Telegram -> TelegramAuth -> Routes;
  Auth -> Routes;
  Auth -> Static -> Browser;
  Browser -> Routes [label="apiData / apiFetch"];
  Browser -> SSE [style=dashed];
  MediaClient -> Strm -> Quark;

  Routes -> Context;
  SSE -> Queue;
  Context -> Services;
  Context -> Queue;
  Context -> Schedulers;
  Context -> Metrics;
  Queue -> Services;
  Schedulers -> Services;
  Services -> Events;
  Queue -> Events;
  Services -> Provider -> Quark;

  Services -> Stores;
  Queue -> Stores;
  Events -> Stores;
  Stores -> Schema -> Data;
  Data -> Backup;

  Services -> Search;
  Services -> TMDB;
  Services -> Aria2;
  Services -> Library;
  Services -> Push;
}
